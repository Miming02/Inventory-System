# Copy to .env and fill with your Supabase project values (Dashboard → Settings → API).
# Local | Staging | Production: use separate Supabase projects or the same project with care.

# Required — public anon key is safe in the browser; never put the service_role key here.
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_public_key_here
